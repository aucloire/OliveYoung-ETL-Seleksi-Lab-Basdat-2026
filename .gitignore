# Python bytecode dan cache (Binary yang dilarang di-upload)
__pycache__/
*.py[cod]
*$py.class

# OS generated files
.DS_Store
Thumbs.db

# Virtual environments (Anaconda biasanya menyimpan env di foldernya sendiri, 
# tapi ini untuk pencegahan jika kamu membuat env lokal)
.env
venv/
env/
ENV/

# IDE files (VSCode, PyCharm, dll)
.vscode/
.idea/

# WebDriver logs
geckodriver.log
chromedriver.log

# JANGAN IGNORE FOLDER DATA JSON!
# Spesifikasi mewajibkan file JSON hasil scraping untuk dikumpulkan.
# Jadi pastikan kamu TIDAK menuliskan data/*.json di sini.